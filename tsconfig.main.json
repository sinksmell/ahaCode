{
  "compilerOptions": {
    "target": "ES2023",
    "rootDir": "src",
    "module": "CommonJS",
    "resolveJsonModule": true,
    "strict": true,
    "inlineSources": true,
    "outDir": "build",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "src/main/i18n/locales/**/*.json"
  ],
  "exclude": [
    "src/main/**/__tests__/**",
    "src/main/**/*.test.ts",
    "src/shared/**/__tests__/**",
    "src/shared/**/*.test.ts"
  ]
}
